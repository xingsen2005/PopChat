{
  "name": "AI-Chat-Desktop",
  "version": "1.0.0",
  "description": "A feature-complete local AI chat desktop application",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "package": "npm run build && electron-builder"
  },
  "keywords": [
    "AI",
    "Chat",
    "Electron",
    "React"
  ],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.5.0",
    "electron": "^30.1.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.19.0",
    "fs-extra": "^11.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "lucide-react": "^0.263.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.aichat.desktop",
    "productName": "AI Chat Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "signingHashAlgorithms": [],
      "sign": false
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
